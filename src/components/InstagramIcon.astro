---
/*
  Small inline Instagram glyph. Inherits currentColor so the accent system can
  tint it per section; decorative (the link text carries the meaning).
*/
---
<svg class="ig-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
  <rect x="3" y="3" width="18" height="18" rx="4.5"></rect>
  <circle cx="12" cy="12" r="4"></circle>
  <circle cx="17.3" cy="6.7" r="1.15" fill="currentColor" stroke="none"></circle>
</svg>
