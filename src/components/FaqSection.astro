---
/*
  FAQ accordion — native <details>/<summary> so it works without JavaScript,
  keyboard-accessible for free, styled to the studio system. Content lives in
  src/data/faqs.ts (which also feeds the FAQPage JSON-LD).
*/
import { withBase } from '../data/site';
import { faqs } from '../data/faqs';
---
<section class="section" id="faq" data-accent="faq">
  <span class="eyebrow" data-reveal>Questions</span>
  <h2 class="disp" data-reveal style="margin-top:.2em;margin-bottom:.6em;font-size:clamp(36px,5.4vw,72px)">Good to know</h2>
  <div class="faq" data-reveal>
    {faqs.map((f) => (
      <details class="faq-item">
        <summary>{f.question}</summary>
        <div class="faq-body">
          <p>{f.answer}</p>
          {f.link && <p style="margin-top:.6em"><a href={withBase(f.link.href)}>{f.link.label}</a></p>}
        </div>
      </details>
    ))}
  </div>
</section>
