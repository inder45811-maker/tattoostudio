---
/*
  The monogram placeholder "fill" — the figmark watermark plus a fine grain
  overlay. Used inside any figure/tile frame that doesn't yet have a real photo
  (hero media, work tiles, artist portraits, story figures). Purely decorative;
  the accessible name lives on the parent frame.
*/
import Monogram from './Monogram.astro';
---
<div class="figmark"><Monogram /></div>
<div class="figgrain"></div>
