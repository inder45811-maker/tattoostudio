---
/*
  Stylised street-map placeholder pinning Regent Street.
  PLACEHOLDER: swap for a real embedded/static map before launch, and confirm
  the exact pin location from the studio's Google Business Profile.
*/
---
<div class="map" role="img" aria-label="Map showing Regent Street, Leamington Spa">
  <svg class="streets" viewBox="0 0 400 320" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
    <g stroke="rgba(242,241,239,.10)" stroke-width="1.5" fill="none">
      <path d="M-20 70 L420 110"></path>
      <path d="M-20 150 L420 190"></path>
      <path d="M-20 240 L420 280"></path>
      <path d="M90 -20 L60 340"></path>
      <path d="M210 -20 L185 340"></path>
      <path d="M320 -20 L300 340"></path>
    </g>
    <path d="M210 -20 L185 340" stroke="rgba(242,241,239,.32)" stroke-width="2.5" fill="none"></path>
  </svg>
  <div class="pin"><div class="dot"></div><span>Regent Street</span></div>
</div>
