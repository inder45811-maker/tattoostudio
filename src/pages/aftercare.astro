---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionBook from '../components/SectionBook.astro';
import { SITE, withBase, breadcrumbSchema, aftercareArticleSchema } from '../data/site';
---
<BaseLayout
  title="Tattoo Aftercare Guide | Making Marks Tattoo Co, Leamington Spa"
  description="How to look after a new tattoo — Making Marks’ aftercare guide covering the first 48 hours, healing, and keeping black & grey work sharp. Leamington Spa."
  canonical={`${SITE.url}/aftercare`}
  ogType="article"
  jsonLd={[breadcrumbSchema('Aftercare', '/aftercare'), aftercareArticleSchema]}
>
  <section class="pagehead" data-accent="care">
    <nav class="crumbs" aria-label="Breadcrumb"><a href={withBase('/')}>Home</a> / <i>Aftercare</i></nav>
    <h1 class="disp" data-reveal>Tattoo aftercare</h1>
    <p class="lede" data-reveal>A new tattoo is an open wound — looking after it well keeps the work crisp for years. Here’s our general guidance.</p>
  </section>

  <section class="section" data-accent="care" style="padding-top:clamp(40px,6vw,72px)">
    <div class="steps" style="margin-top:0">
      <article class="step" data-reveal>
        <span class="step-no">Step 01</span>
        <h2>The first 24–48 hours</h2>
        <ul>
          <li>Leave the covering on for as long as your artist advises.</li>
          <li>Wash gently with clean hands and a fragrance-free soap, then pat dry with a clean towel.</li>
          <li>Apply a thin layer of the aftercare balm we recommend — less is more.</li>
        </ul>
      </article>
      <article class="step" data-reveal>
        <span class="step-no">Step 02</span>
        <h2>While it heals (roughly two weeks)</h2>
        <ul>
          <li>Keep it clean and moisturise lightly two to three times a day.</li>
          <li>Don’t pick or scratch — flaking and light scabbing is normal, let it fall away on its own.</li>
          <li>Avoid soaking: no baths, swimming, saunas or steam rooms.</li>
          <li>Avoid tight clothing rubbing over the area.</li>
        </ul>
      </article>
      <article class="step" data-reveal>
        <span class="step-no">Step 03</span>
        <h2>Once it’s healed</h2>
        <ul>
          <li>Keep it out of direct sun while healing, and use a high SPF afterwards to keep black &amp; grey looking sharp.</li>
          <li>Moisturise regularly — well-kept skin holds a tattoo beautifully over time.</li>
        </ul>
      </article>
    </div>
    <div class="prose" style="margin-top:clamp(28px,4vw,44px)">
      <div class="callout" data-reveal><strong>If something doesn’t feel right</strong> — increasing redness, swelling, heat or any discharge — speak to a pharmacist or GP. And always follow the specific aftercare advice your artist gives you on the day; it takes priority over any general guide.</div>
    </div>
  </section>

  <SectionBook title="Questions about your healing?" text="Drop us a message — we’re happy to help at any stage.">
    <a class="btn btn--solid" href={SITE.links.instagram} target="_blank" rel="noopener">Message on Instagram</a>
    <a class="btn btn--ghost" href={SITE.links.email}>Email us</a>
  </SectionBook>
</BaseLayout>
